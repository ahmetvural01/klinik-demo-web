    "build:clean": "node scripts/ensure-postgres.mjs && node scripts/clean-next.mjs && next build",
    "build:render": "prisma generate && next build",
    "start": "next start",
    "start:render": "node scripts/start-render.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "demo:hasta-takip:load": "tsx scripts/load-hasta-takip-demo.ts",
    "demo:hasta-takip:clear": "tsx scripts/clear-hasta-takip-demo.ts",
    "demo:full:load": "tsx scripts/load-full-demo-package.ts",
    "loadtest:realtime:240": "tsx scripts/loadtest-realtime-240.ts",
    "test:smoke": "tsx scripts/smoke-api.ts",
    "worker:sms": "tsx scripts/sms-worker.ts",
    "verify:redis:realtime": "tsx scripts/verify-redis-realtime.ts",
    "test:integration": "tsx scripts/integration-basic.ts",
    "preflight:prod": "tsx scripts/preflight-prod.ts",
    "backup:db": "node scripts/backup-postgres.mjs",
    "encrypt:legacy-data": "tsx scripts/encrypt-existing-sensitive-data.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/jsbarcode": "^3.11.4",
    "@types/nodemailer": "^8.0.0",
    "@types/papaparse": "^5.5.2",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.10.1",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.462.0",
    "next": "14.2.35",
    "nodemailer": "^8.0.7",
    "otplib": "^12.0.1",
    "papaparse": "^5.5.4",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "signature_pad": "^5.1.3",
    "zod": "^3.23.8"
