  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "20.16.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "8.4.45",
    "prisma": "^5.17.0",
    "tailwindcss": "3.4.13",
    "tsx": "^4.19.1",
    "typescript": "5.5.4"
  }
