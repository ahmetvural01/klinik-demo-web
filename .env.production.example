# Render / Neon production-demo ortamı için şablon.
# Bu dosya örnektir; gerçek değerler Render Environment ekranına girilmelidir.

NODE_ENV="production"
APP_URL="https://RENDER-SERVICE.onrender.com"
APP_NAME="Klinik Yönetim Paneli"

# Neon PostgreSQL direct connection string.
# Örnek format:
# postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&schema=public
DATABASE_URL=""

# Güçlü ve benzersiz üretim değerleri kullanın.
JWT_SECRET=""
FIELD_ENCRYPTION_KEY=""
SMTP_MASTER_PASSWORD=""

# Opsiyonel güvenlik anahtarı.
SUPERADMIN_MASTER_SECRET=""

# SMS entegrasyonu kullanılacaksa doldurun veya superadmin panelinden sağlayıcı tanımlayın.
SMS_PROVIDER="NETGSM"
NETGSM_USERCODE=""
NETGSM_PASSWORD=""
NETGSM_HEADER=""

# Opsiyonel. Render tek web service demo kurulumunda boş bırakılabilir.
# Çoklu worker / ayrı SMS worker / daha tutarlı SSE için Redis servisi tanımlayın.
REDIS_URL=""
SMS_QUEUE_KEY="ks:sms:jobs"

# Sadece sahte demo verisi elle yüklenecekse kullanın.
DEMO_PASSWORD=""
