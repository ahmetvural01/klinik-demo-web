generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Institution {
  id                  String                    @id @default(cuid())
  name                String                    @unique
  email               String                    @unique
  phone               String?
  address             String?
  taxNo               String?                   @unique
  registryNo          String?
  website             String?
  logo                String?
  subscriptionPlan    SubscriptionPlan          @default(TEMEL)
  billingCycle        BillingCycle              @default(AYLIK)
  smsBalance          Int                       @default(0)
  isActive            Boolean                   @default(true)
  ownerId             String?                   @unique
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  adIntensity         AdIntensity               @default(MEDIUM)
  adsEnabled          Boolean                   @default(false)
  maxActiveDoctors    Int?
  maxActiveUsers      Int?
  paymentGraceUntil   DateTime?
  serviceMode         ServiceMode               @default(NORMAL)
  serviceNote         String?
  suspendedUntil      DateTime?
  throttleMs          Int                       @default(0)
  isDemo              Boolean                   @default(false)
  demoExpiresAt       DateTime?
  demoSourceRequestId String?
  owner               User?                     @relation("InstitutionOwner", fields: [ownerId], references: [id])
  adAssignments       InstitutionAdAssignment[]
  announcements       Announcement[]
  clinicTasks         ClinicTask[]
  demoRequests        DemoRequest[]             @relation("DemoRequestInstitution")
  invoices            Invoice[]
  patients            Patient[]
  priceItems          PriceItem[]
  settings            Setting?
  smsTransactions     SmsTransaction[]
  stockItems          StockItem[]
  expenseCategories   ExpenseCategory[]
  expenses            Expense[]
  firmas              Firma[]
  purchases           Purchase[]
  posDevices          PosDevice[]
  users               User[]
  documents           Document[]
  waitlistEntries     Waitlist[]
  bookingRequests     BookingRequest[]
  treatmentTypes      TreatmentType[]
  consentTemplates    ConsentTemplate[]
  patientConsents     PatientConsent[]
}

model DemoRequest {
  id                String       @id @default(cuid())
  institutionName   String
  contactName       String
  email             String
  phone             String?
  notes             String?
  status            String       @default("DEMO_CREATED")
  demoInstitutionId String?
  demoExpiresAt     DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  demoInstitution   Institution? @relation("DemoRequestInstitution", fields: [demoInstitutionId], references: [id])

  @@index([email])
  @@index([status])
  @@index([demoInstitutionId])
  @@index([createdAt])
}

model Advertisement {
  id             String                    @id @default(cuid())
  title          String
  content        String
  imageUrl       String?
  ctaText        String?
  ctaUrl         String?
  sponsorName    String?
  priority       Int                       @default(100)
  isActive       Boolean                   @default(true)
  startAt        DateTime?
  endAt          DateTime?
  maxImpressions Int?
  dailyCap       Int?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  assignments    InstitutionAdAssignment[]

  @@index([isActive, priority])
}

model InstitutionAdAssignment {
  id              String        @id @default(cuid())
  institutionId   String
  advertisementId String
  isActive        Boolean       @default(true)
  weight          Int           @default(100)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id])
  institution     Institution   @relation(fields: [institutionId], references: [id])

  @@unique([institutionId, advertisementId])
  @@index([institutionId, isActive])
}

model SmsPackage {
  id           String           @id @default(cuid())
  name         String
  smsCount     Int              @unique
  price        Decimal          @db.Decimal(10, 2)
  description  String?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  transactions SmsTransaction[]
}

model SmsTransaction {
  id            String      @id @default(cuid())
  institutionId String
  smsPackageId  String
  quantity      Int         @default(1)
  totalPrice    Decimal     @db.Decimal(10, 2)
  balanceBefore Int
  balanceAfter  Int
  status        String      @default("COMPLETED")
  createdAt     DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id])
  smsPackage    SmsPackage  @relation(fields: [smsPackageId], references: [id])

  @@index([institutionId])
  @@index([createdAt])
}

model PlatformSmsWallet {
  id               Int                   @id @default(autoincrement())
  availableBalance Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  purchases        PlatformSmsPurchase[]
}

model PlatformSmsPurchase {
  id        String            @id @default(cuid())
  walletId  Int
  quantity  Int
  unitCost  Decimal?          @db.Decimal(10, 2)
  totalCost Decimal?          @db.Decimal(10, 2)
  provider  String?
  note      String?
  createdAt DateTime          @default(now())
  wallet    PlatformSmsWallet @relation(fields: [walletId], references: [id])
}

model SmsTemplate {
  id        String   @id @default(cuid())
  code      String   @unique
  title     String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SmsProviderConfig {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  isActive       Boolean  @default(false)
  priority       Int      @default(100)
  sendUrl        String?
  balanceUrl     String?
  httpMethod     String   @default("POST")
  username       String?
  password       String?
  apiKey         String?
  sender         String?
  headersJson    String?
  bodyTemplate   String?
  successPattern String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MockSmsLog {
  id           String   @id @default(cuid())
  phone        String
  message      String
  sender       String?
  status       String   @default("SENT")
  responseData String?
  createdAt    DateTime @default(now())
}

model Invoice {
  id            String            @id @default(cuid())
  institutionId String
  invoiceNo     String            @unique
  amount        Decimal           @db.Decimal(10, 2)
  description   String?
  status        InvoiceStatus     @default(PENDING)
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  institution   Institution       @relation(fields: [institutionId], references: [id])
  reminders     InvoiceReminder[]

  @@index([institutionId])
  @@index([status])
  @@index([dueDate])
  @@index([institutionId, status])
}

model InvoiceReminder {
  id          String   @id @default(cuid())
  invoiceId   String
  channel     String
  sentTo      String
  status      String
  message     String?
  errorDetail String?
  sentAt      DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

model SmtpConfig {
  id        Int      @id @default(1)
  host      String   @default("")
  port      Int      @default(587)
  secure    Boolean  @default(false)
  username  String   @default("")
  password  String   @default("")
  fromName  String   @default("Klinik Yönetim Paneli")
  fromEmail String   @default("noreply@klinik.local")
  isActive  Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// Tüm platform için tek, sistem geneli aktif görsel tema (renk paleti + yazı
// tipi). Kurum bazlı değil — SiteContent gibi tek satırlık bir singleton.
model PlatformTheme {
  id          Int      @id @default(1)
  activeTheme String   @default("klasik")
  updatedAt   DateTime @updatedAt
}

model SiteContent {
  id                Int      @id @default(1)
  heroBadge         String   @default("Dis Hekimi Klinikleri Icin Uretildi")
  heroTitle         String   @default("Randevudan kasaya, tum surecler tek bir profesyonel sistemde.")
  heroDescription   String   @default("Hasta kayıt, randevu planlama, tedavi takibi, ödeme yönetimi, SMS/e-posta hatırlatma ve raporlama modüllerini bir arada sunar.")
  primaryCtaLabel   String   @default("Hemen Giris Yap")
  primaryCtaUrl     String   @default("/klinik/giris")
  secondaryCtaLabel String   @default("Fiyatlari Incele")
  secondaryCtaUrl   String   @default("#fiyatlar")
  promoTitle        String   @default("Program Demo ve Tanitim Talebi")
  promoDescription  String   @default("Kliniğinize özel senaryo üzerinden canlı tanıtım alarak modülleri gerçek kullanım akışında görebilirsiniz.")
  promoVideoUrl     String?
  heroImageUrl      String?
  featureCards      Json
  pricingCards      Json
  statsCards        Json
  moduleCards       Json
  galleryImages     Json
  showAnimations    Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}

model User {
  id                      String                 @id @default(cuid())
  // TC kimlik no SADECE kurum içinde benzersizdir (bkz. @@unique([institutionId, identityNo])
  // aşağıda) — global @unique KASITLI OLARAK kaldırıldı. Aksi halde iki farklı klinik
  // aynı TC'ye (rastgele çakışma veya test verisi) sahip personel ekleyemez, hatta
  // birinin kaydı diğerini bulan sorgularla karışabilirdi (kritik çoklu kiracı hatası).
  identityNo              String
  fullName                String
  email                   String?                @unique
  passwordHash            String
  role                    Role                   @default(DOKTOR)
  isActive                Boolean                @default(true)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  institutionId           String?
  genelYuzde              Decimal?               @db.Decimal(5, 2)
  kkYuzde                 Decimal?               @db.Decimal(5, 2)
  maasYuzde               Decimal?               @db.Decimal(5, 2)
  appointments            Appointment[]
  logs                    AuditLog[]
  examinations            Examination[]
  ownedInstitution        Institution?           @relation("InstitutionOwner")
  labOrders               LabOrder[]             @relation("LabOrderDoctor")
  paymentsAsDoctor        Payment[]              @relation("PaymentDoctor")
  prescriptions           Prescription[]         @relation("PrescriptionDoctor")
  messages                Message[]
  profile                 Profile?
  assignedFollowUps       PatientFollowUp[]      @relation("FollowUpAssignedDoctor")
  createdFollowUps        PatientFollowUp[]      @relation("FollowUpCreatedBy")
  createdFollowEvents     PatientFollowUpEvent[] @relation("FollowUpEventCreatedBy")
  updatedFollowEvents     PatientFollowUpEvent[] @relation("FollowUpEventUpdatedBy")
  stockMovements          StockMovement[]        @relation("StockMovementUser")
  superadminPermission    SuperadminPermission?
  supportTickets          SupportTicket[]
  taksitPlanlari          TaksitPlan[]           @relation("TaksitPlanDoctor")
  treatmentPlans          TreatmentPlan[]        @relation("TreatmentPlanDoctor")
  doctorBlocks            DoctorBlock[]
  assignedClinicTasks     ClinicTask[]           @relation("ClinicTaskAssignedUser")
  clinicTaskAssignments   ClinicTaskAssignee[]
  createdClinicTasks      ClinicTask[]           @relation("ClinicTaskCreatedBy")
  institution             Institution?           @relation(fields: [institutionId], references: [id])
  uploadedDocuments       Document[]
  createdConsents         PatientConsent[]       @relation("ConsentCreatedBy")
  waitlistCreated         Waitlist[]             @relation("WaitlistCreatedBy")
  waitlistAsDoctor        Waitlist[]             @relation("WaitlistDoctor")
  bookingRequestsAsDoctor BookingRequest[]
  doctorPayoutExpenses    Expense[]              @relation("ExpenseDoctor")
  purchasesCreated        Purchase[]             @relation("PurchaseCreatedBy")
  twoFactorSecret         String?
  twoFactorEnabled        Boolean                @default(false)
  twoFactorBackupCodes    String?

  @@unique([institutionId, identityNo])
}

model SuperadminPermission {
  id        String   @id @default(cuid())
  userId    String   @unique
  modules   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id            String   @id @default(cuid())
  userId        String   @unique
  photoUrl      String?
  workStart     String   @default("08:30")
  workEnd       String   @default("18:00")
  hideAsDoctor  Boolean  @default(false)
  educationMode Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}

model Patient {
  id              String                 @id @default(cuid())
  institutionId   String?
  tcNo            String
  fullName        String
  phone           String
  address         String?
  profession      String?
  gender          String
  birthDate       DateTime?
  insurance       String?
  discountRate    Int                    @default(0)
  notes           String?
  hasAllergy      Boolean                @default(false)
  hasHepatitis    Boolean                @default(false)
  hasKidney       Boolean                @default(false)
  hasDiabetes     Boolean                @default(false)
  hasHeart        Boolean                @default(false)
  hasBloodIssue   Boolean                @default(false)
  hasContagiousDisease  Boolean          @default(false)
  contagiousDiseaseNote String?
  surgeries       String?
  medications     String?
  otherDiseases   String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  bloodType       String?
  toothChart      String?
  referrer        String?
  institution     Institution?           @relation(fields: [institutionId], references: [id])
  appointments    Appointment[]
  examinations    Examination[]
  labOrders       LabOrder[]
  payments        Payment[]
  prescriptions   Prescription[]
  reminders       Reminder[]
  followUps       PatientFollowUp[]
  followUpEvents  PatientFollowUpEvent[]
  clinicTasks     ClinicTask[]
  taksitPlanlari  TaksitPlan[]
  treatmentPlans  TreatmentPlan[]
  documents       Document[]
  consents        PatientConsent[]
  waitlistEntries Waitlist[]

  @@unique([institutionId, tcNo])
  @@index([institutionId])
  @@index([fullName])
  @@index([phone])
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  doctorId    String
  startAt     DateTime
  endAt       DateTime
  colorCode   String            @default("#2a9d8f")
  type        AppointmentType   @default(STANDART)
  note        String?
  smsInfo     Boolean           @default(true)
  smsReminder Boolean           @default(false)
  smsSurvey   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  status      String            @default("BEKLIYOR")
  doctor      User              @relation(fields: [doctorId], references: [id])
  followUps   PatientFollowUp[]
  patient     Patient           @relation(fields: [patientId], references: [id])
  waitlistEntries Waitlist[]

  @@index([doctorId])
  @@index([patientId])
  @@index([startAt])
  @@index([doctorId, startAt])
}

model ClinicTask {
  id            String               @id @default(cuid())
  institutionId String
  patientId     String?
  title         String
  details       String?
  vendorName    String?
  type          ClinicTaskType       @default(DIGER)
  priority      Int                  @default(2)
  status        ClinicTaskStatus     @default(ACIK)
  dueAt         DateTime?
  remindAt      DateTime?
  assignedToId  String?
  createdById   String
  completedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  institution   Institution          @relation(fields: [institutionId], references: [id])
  patient       Patient?             @relation(fields: [patientId], references: [id])
  assignedTo    User?                @relation("ClinicTaskAssignedUser", fields: [assignedToId], references: [id])
  assignees     ClinicTaskAssignee[]
  createdBy     User                 @relation("ClinicTaskCreatedBy", fields: [createdById], references: [id])

  @@index([institutionId, status, dueAt])
  @@index([institutionId, patientId])
  @@index([assignedToId, status])
}

model ClinicTaskAssignee {
  id        String     @id @default(cuid())
  taskId    String
  userId    String
  createdAt DateTime   @default(now())
  task      ClinicTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@index([taskId])
}

model PatientFollowUp {
  id             String                 @id @default(cuid())
  patientId      String
  appointmentId  String?
  doctorId       String?
  createdById    String
  type           FollowUpType           @default(GERI_ARA)
  priority       Int                    @default(2)
  status         String                 @default("ACIK")
  note           String?
  resolutionNote String?
  nextActionAt   DateTime?
  lastContactAt  DateTime?
  closedAt       DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  // Lab provası nedeniyle açılan takiplerin kaynağı önceden yalnızca `note`
  // metnine gömülü "LAB_ORDER:"/"LAB_PROVA:" etiketleriyle bulunuyordu — not
  // düzenlenirse bağ sessizce kopuyordu (bkz. denetim raporu Tema 3).
  labOrderId     String?
  labTripId      String?
  appointment    Appointment?           @relation(fields: [appointmentId], references: [id])
  assignedDoctor User?                  @relation("FollowUpAssignedDoctor", fields: [doctorId], references: [id])
  createdBy      User                   @relation("FollowUpCreatedBy", fields: [createdById], references: [id])
  patient        Patient                @relation(fields: [patientId], references: [id])
  labOrder       LabOrder?              @relation(fields: [labOrderId], references: [id])
  labTrip        LabTrip?               @relation(fields: [labTripId], references: [id])
  events         PatientFollowUpEvent[]

  @@index([patientId])
  @@index([appointmentId])
  @@index([doctorId])
  @@index([createdById])
  @@index([status, nextActionAt])
  @@index([createdAt])
  @@index([labOrderId])
  @@index([labTripId])
}

model PatientFollowUpEvent {
  id              String          @id @default(cuid())
  followUpId      String
  patientId       String
  occurredAt      DateTime
  channel         String?
  summary         String
  detail          String?
  patientResponse String?
  nextStep        String?
  createdById     String
  updatedById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  followUp        PatientFollowUp @relation(fields: [followUpId], references: [id], onDelete: Cascade)
  patient         Patient         @relation(fields: [patientId], references: [id])
  createdBy       User            @relation("FollowUpEventCreatedBy", fields: [createdById], references: [id])
  updatedBy       User            @relation("FollowUpEventUpdatedBy", fields: [updatedById], references: [id])

  @@index([followUpId, occurredAt])
  @@index([patientId, occurredAt])
  @@index([createdAt])
}

model ConsentTemplate {
  id            String           @id @default(cuid())
  institutionId String?
  title         String
  category      String           @default("TEDAVI_ONAM")
  body          String
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  institution   Institution?     @relation(fields: [institutionId], references: [id])
  consents      PatientConsent[]

  @@index([institutionId, isActive])
  @@index([category])
}

model PatientConsent {
  id               String           @id @default(cuid())
  institutionId    String?
  patientId        String
  templateId       String?
  title            String
  category         String           @default("TEDAVI_ONAM")
  body             String
  signerName       String
  signerIdentityNo String?
  signatureDataUrl String
  status           String           @default("AKTIF")
  voidedAt         DateTime?
  voidReason       String?
  voidedById       String?
  signedAt         DateTime         @default(now())
  createdById      String
  createdAt        DateTime         @default(now())
  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  template         ConsentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy        User             @relation("ConsentCreatedBy", fields: [createdById], references: [id])
  institution      Institution?     @relation(fields: [institutionId], references: [id])

  @@index([institutionId])
  @@index([status])
  @@index([patientId, signedAt])
  @@index([templateId])
}

model Examination {
  id            String   @id @default(cuid())
  patientId     String
  doctorId      String
  treatmentName String
  toothNo       String?
  amount        Decimal  @db.Decimal(10, 2)
  status        String
  diagnosedAt   DateTime
  note          String?
  createdAt     DateTime @default(now())
  doctor        User     @relation(fields: [doctorId], references: [id])
  patient       Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([doctorId])
}

model Payment {
  id             String        @id @default(cuid())
  patientId      String?
  doctorId       String?
  method         PaymentMethod @default(NAKIT)
  amount         Decimal       @db.Decimal(10, 2)
  description    String?
  createdAt      DateTime      @default(now())
  posId          String?
  patient        Patient?      @relation(fields: [patientId], references: [id])
  doctor         User?         @relation("PaymentDoctor", fields: [doctorId], references: [id])
  pos            PosDevice?    @relation(fields: [posId], references: [id])
  taksitOdemeler TaksitOdeme[]

  @@index([patientId])
  @@index([doctorId])
  @@index([posId])
  @@index([createdAt])
}

model PriceItem {
  id            String       @id @default(cuid())
  institutionId String?
  code          String
  treatment     String
  amount        Decimal      @db.Decimal(10, 2)
  isFavorite    Boolean      @default(false)
  isCustom      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  institution   Institution? @relation(fields: [institutionId], references: [id])

  @@unique([institutionId, code, treatment])
  @@index([institutionId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  detail    String?
  /// Gerçek işlemi yapan kullanıcı (ghost/superadmin oturumlarında userId'den farklı olabilir)
  actorId   String?
  actorRole String?
  isGhost   Boolean  @default(false)
  ip        String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([actorId])
}

model Setting {
  id                  String      @id @default(cuid())
  institutionName     String
  institutionAddress  String?
  institutionPhone    String?
  institutionWebsite  String?
  openingTime         String      @default("08:30")
  closingTime         String      @default("23:00")
  appointmentDuration Int         @default(15)
  holidayDays         String      @default("[]")
  // Günlük özel çalışma saatleri: JSON array of {day:"pazartesi",open:"08:30",close:"17:00",lunchStart:"12:00",lunchEnd:"13:00",isHoliday:false}
  dailySchedules      String      @default("[]")
  // Genel öğle arası (günlük override yoksa kullanılır)
  lunchStart          String      @default("")
  lunchEnd            String      @default("")
  smsEnabled          Boolean     @default(true)
  smsDefaultInfo      Boolean     @default(true)
  smsDefaultReminder  Boolean     @default(false)
  smsDefaultSurvey    Boolean     @default(false)
  updatedAt           DateTime    @updatedAt
  institutionId       String      @unique
  activePriceList     String      @default("standard")
  followUpCustomTypes String      @default("[]")
  institution         Institution @relation(fields: [institutionId], references: [id])
}

// Kuruma özel randevu tedavi türleri ve renkleri (Ayarlar > Tedavi Türleri)
model TreatmentType {
  id            String      @id @default(cuid())
  institutionId String
  value         String
  label         String
  color         String      @default("#2563eb")
  order         Int         @default(0)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, value])
  @@index([institutionId, order])
}

// Doktor bazlı zaman blokajı (belirli tarih/saat aralığında randevuya kapalı)
model DoctorBlock {
  id        String   @id @default(cuid())
  doctorId  String
  date      String // YYYY-MM-DD
  startTime String // HH:mm
  endTime   String // HH:mm
  reason    String?
  createdAt DateTime @default(now())
  doctor    User     @relation(fields: [doctorId], references: [id])

  @@index([doctorId, date])
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String?
  subject   String
  message   String
  answer    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Message {
  id        String   @id @default(cuid())
  userId    String
  text      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Announcement {
  id            String       @id @default(cuid())
  institutionId String?
  text          String
  isActive      Boolean      @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdById   String?
  createdAt     DateTime     @default(now())
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, isActive, createdAt])
}

model Prescription {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String?
  drugs     String
  note      String?
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])
  doctor    User?    @relation("PrescriptionDoctor", fields: [doctorId], references: [id])

  @@index([patientId])
  @@index([doctorId])
}

model TreatmentPlan {
  id        String              @id @default(cuid())
  patientId String
  doctorId  String
  title     String
  status    TreatmentPlanStatus @default(PLANLANDI)
  totalCost Decimal?            @db.Decimal(10, 2)
  notes     String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  doctor    User                @relation("TreatmentPlanDoctor", fields: [doctorId], references: [id])
  patient   Patient             @relation(fields: [patientId], references: [id])
  steps     TreatmentStep[]

  @@index([patientId])
  @@index([doctorId])
}

model TreatmentStep {
  id            String        @id @default(cuid())
  planId        String
  order         Int
  treatmentName String
  toothNo       String?
  amount        Decimal       @db.Decimal(10, 2)
  status        String        @default("BEKLIYOR")
  doneAt        DateTime?
  note          String?
  createdAt     DateTime      @default(now())
  plan          TreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

model LabOrder {
  id        String            @id @default(cuid())
  patientId String
  doctorId  String
  // labName tarihsel/gösterim amaçlı serbest metin olarak kalır; asıl ilişki
  // firmaId ile kurulur (bkz. denetim raporu Tema 3 — önceden yalnızca isim
  // eşleşmesiyle kuruluyordu, firma adı değişince zincir kopabiliyordu).
  labName   String
  firmaId   String?
  labType   String
  teeth     String?
  notes     String?
  status    LabOrderStatus    @default(DEVAM_EDIYOR)
  price     Decimal?          @db.Decimal(10, 2)
  invoiceNo String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  doctor    User              @relation("LabOrderDoctor", fields: [doctorId], references: [id])
  firma     Firma?            @relation(fields: [firmaId], references: [id])
  invoices  LabOrderInvoice[]
  patient   Patient           @relation(fields: [patientId], references: [id])
  trips     LabTrip[]
  followUps PatientFollowUp[]

  @@index([patientId])
  @@index([doctorId])
  @@index([firmaId])
}

model LabTrip {
  id           String    @id @default(cuid())
  labOrderId   String
  order        Int
  description  String
  sentAt       DateTime  @default(now())
  expectedAt   DateTime?
  followUps    PatientFollowUp[]
  receivedAt   DateTime?
  sentNote     String?
  receivedNote String?
  createdAt    DateTime  @default(now())
  labOrder     LabOrder  @relation(fields: [labOrderId], references: [id], onDelete: Cascade)

  @@unique([labOrderId, order])
  @@index([labOrderId])
}

model LabOrderInvoice {
  id         String   @id @default(cuid())
  labOrderId String
  item       String
  amount     Decimal  @db.Decimal(10, 2)
  invoiceNo  String?
  issuedAt   DateTime @default(now())
  note       String?
  createdAt  DateTime @default(now())
  labOrder   LabOrder @relation(fields: [labOrderId], references: [id], onDelete: Cascade)

  @@unique([labOrderId, invoiceNo])
  @@index([labOrderId])
  @@index([issuedAt])
}

model StockItem {
  id              String          @id @default(cuid())
  institutionId   String?
  name            String
  category        String          @default("SARF")
  unit            String          @default("adet")
  quantity        Int             @default(0)
  minQuantity     Int             @default(5)
  unitPrice       Decimal?        @db.Decimal(10, 2)
  supplier        String?
  barcode         String?
  expiresAt       DateTime?
  storageLocation String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  institution     Institution?    @relation(fields: [institutionId], references: [id])
  movements       StockMovement[]
  purchaseItems   PurchaseItem[]

  // Aynı isimde birden fazla stok kartı açılabiliyordu (satın almadaki
  // eşleştirme mantığı büyük/küçük harf duyarsızdı ama veritabanında bunu
  // garanti eden bir kısıt yoktu — eşzamanlı iki "yeni ürün" isteği veya
  // "Yeni Kart" formundan elle tekrar aynı isim girilmesi mükerrer kart
  // yaratabiliyordu). Firma modeliyle aynı desen.
  @@unique([institutionId, name])
  @@index([institutionId])
  @@index([barcode])
  @@index([expiresAt])
}

model StockMovement {
  id           String        @id @default(cuid())
  stockItemId  String
  type         String
  quantity     Int
  unitPrice    Decimal?      @db.Decimal(10, 2)
  supplier     String?
  note         String?
  userId       String
  createdAt    DateTime      @default(now())
  stockItem    StockItem     @relation(fields: [stockItemId], references: [id])
  user         User          @relation("StockMovementUser", fields: [userId], references: [id])
  purchaseItem PurchaseItem?

  @@index([stockItemId, createdAt])
}

model TaksitPlan {
  id           String           @id @default(cuid())
  patientId    String
  doctorId     String
  baslik       String?
  toplamBorc   Decimal          @db.Decimal(10, 2)
  pesnat       Decimal          @default(0) @db.Decimal(10, 2)
  taksitSayisi Int
  period       TaksitPeriod     @default(AYLIK)
  startDate    DateTime
  notes        String?
  status       TaksitPlanStatus @default(AKTIF)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  reminders    Reminder[]
  taksitler    Taksit[]
  doctor       User             @relation("TaksitPlanDoctor", fields: [doctorId], references: [id])
  patient      Patient          @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

model Taksit {
  id        String        @id @default(cuid())
  planId    String
  siraNo    Int
  vadeDate  DateTime
  tutar     Decimal       @db.Decimal(10, 2)
  odenen    Decimal       @default(0) @db.Decimal(10, 2)
  kalan     Decimal       @db.Decimal(10, 2)
  status    TaksitStatus  @default(BEKLIYOR)
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  plan      TaksitPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  odemeler  TaksitOdeme[]

  @@index([planId])
  @@index([vadeDate])
  @@index([status])
}

model TaksitOdeme {
  id        String        @id @default(cuid())
  taksitId  String
  paymentId String?
  tarih     DateTime      @default(now())
  tutar     Decimal       @db.Decimal(10, 2)
  yontem    PaymentMethod @default(NAKIT)
  posId     String?
  note      String?
  createdAt DateTime      @default(now())
  payment   Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  pos       PosDevice?    @relation(fields: [posId], references: [id])
  taksit    Taksit        @relation(fields: [taksitId], references: [id], onDelete: Cascade)

  @@index([taksitId])
  @@index([paymentId])
}

model PosDevice {
  id             String        @id @default(cuid())
  institutionId  String?
  name           String
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  institution    Institution?  @relation(fields: [institutionId], references: [id])
  payments       Payment[]
  taksitOdemeler TaksitOdeme[]

  @@unique([institutionId, name])
  @@index([institutionId])
}

model ExpenseCategory {
  id             String       @id @default(cuid())
  institutionId  String?
  name           String
  isActive       Boolean      @default(true)
  // Bu tür seçildiğinde gider formu doktor + hakediş dönemi (yıl/ay) alanlarını
  // gösterir ve kayıt o doktorun aylık hakediş bakiyesinden düşülür.
  isDoctorPayout Boolean      @default(false)
  createdAt      DateTime     @default(now())
  institution    Institution? @relation(fields: [institutionId], references: [id])
  expenses       Expense[]

  @@unique([institutionId, name])
  @@index([institutionId])
}

model Expense {
  id              String           @id @default(cuid())
  institutionId   String?
  tarih           DateTime
  categoryId      String?
  category        String
  description     String?
  tutar           Decimal          @db.Decimal(10, 2)
  yontem          PaymentMethod    @default(NAKIT)
  faturaNo        String?
  kdvOrani        Int              @default(0)
  status          String           @default("AKTIF")
  // Doktor hakediş ödemesi kayıtları için: hangi doktora, hangi hakediş dönemine
  // (yıl/ay) ait olduğu. İkisi de null ise normal (doktora bağlı olmayan) gider.
  doctorId        String?
  periodYear      Int?
  periodMonth     Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  institution     Institution?     @relation(fields: [institutionId], references: [id])
  expenseCategory ExpenseCategory? @relation(fields: [categoryId], references: [id])
  doctor          User?            @relation("ExpenseDoctor", fields: [doctorId], references: [id])

  @@index([institutionId])
  @@index([tarih])
  @@index([status])
  @@index([doctorId, periodYear, periodMonth])
}

model Firma {
  id                String           @id @default(cuid())
  institutionId     String?
  name              String
  phone             String?
  iban              String?
  ibanName          String?
  notes             String?
  kategori          FirmaKategori    @default(TEDARICI)
  paymentTerms      PaymentTermType? @default(NET_30)
  customPaymentDays Int?
  vendorScore       Int              @default(0)
  scoreUpdatedAt    DateTime?
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  institution       Institution?     @relation(fields: [institutionId], references: [id])
  islemler          FirmaIslem[]
  kontaktler        FirmaKontakt[]
  purchases         Purchase[]
  labOrders         LabOrder[]

  @@unique([institutionId, name])
  @@index([institutionId])
  @@index([kategori])
  @@index([vendorScore])
}

model FirmaIslem {
  id         String         @id @default(cuid())
  firmaId    String
  tarih      DateTime
  islemTipi  FirmaIslemTipi @default(ALIM)
  urunHizmet String?
  aciklama   String?
  tutar      Decimal        @db.Decimal(10, 2)
  faturaNo   String?
  yontem     PaymentMethod?
  dueDate    DateTime?
  kdvOrani   Int            @default(0)
  status     String         @default("AKTIF")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  firma      Firma          @relation(fields: [firmaId], references: [id])
  purchase   Purchase?

  @@index([firmaId])
  @@index([tarih])
  @@index([dueDate])
}

model FirmaKontakt {
  id        String   @id @default(cuid())
  firmaId   String
  ad        String
  unvan     String?
  email     String?
  telefon   String?
  rol       String?
  isPrimary Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  firma     Firma    @relation(fields: [firmaId], references: [id], onDelete: Cascade)

  @@index([firmaId])
  @@index([email])
}

// Çok kalemli satın alma belgesi. Toplam tutar tek bir ALIM tipi FirmaIslem'e
// bağlanır (firma bakiyesi/ekstre hesabı hiç değişmeden çalışmaya devam eder);
// satır detayları (hangi üründen kaç adet, hangi fiyattan) burada tutulur.
model Purchase {
  id            String         @id @default(cuid())
  institutionId String?
  firmaId       String
  firmaIslemId  String         @unique
  tarih         DateTime
  faturaNo      String?
  aciklama      String?
  kdvOrani      Int            @default(0)
  status        String         @default("AKTIF")
  createdById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  institution   Institution?   @relation(fields: [institutionId], references: [id])
  firma         Firma          @relation(fields: [firmaId], references: [id])
  firmaIslem    FirmaIslem     @relation(fields: [firmaIslemId], references: [id])
  createdBy     User?          @relation("PurchaseCreatedBy", fields: [createdById], references: [id])
  items         PurchaseItem[]

  @@index([institutionId])
  @@index([firmaId])
  @@index([tarih])
}

model PurchaseItem {
  id              String         @id @default(cuid())
  purchaseId      String
  stockItemId     String
  productName     String
  quantity        Int
  unit            String         @default("adet")
  unitPrice       Decimal        @db.Decimal(10, 2)
  lineTotal       Decimal        @db.Decimal(10, 2)
  stockMovementId String?        @unique
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  purchase        Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  stockItem       StockItem      @relation(fields: [stockItemId], references: [id])
  stockMovement   StockMovement? @relation(fields: [stockMovementId], references: [id])

  @@index([purchaseId])
  @@index([stockItemId])
}

model Reminder {
  id           String         @id @default(cuid())
  patientId    String?
  planId       String?
  note         String
  reminderDate DateTime
  status       ReminderStatus @default(AKTIF)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  patient      Patient?       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  plan         TaksitPlan?    @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([reminderDate])
  @@index([status])
}

enum Role {
  YONETICI
  DOKTOR
  ASISTAN
  BANKO
  MUHASEBE
  SUPERADMIN
}

enum SubscriptionPlan {
  TEMEL
  PROFESYONEL
  KURUMSAL
}

enum ServiceMode {
  NORMAL
  LIMITED
  READ_ONLY
  SUSPENDED
}

enum BillingCycle {
  AYLIK
  YILLIK
}

enum AdIntensity {
  LOW
  MEDIUM
  HIGH
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum AppointmentType {
  STANDART
  KONTROL
  ACIL
}

enum FollowUpType {
  GERI_ARA
  ULASILAMADI
  DONUS_BEKLENIYOR
  DIGER
}

enum PaymentMethod {
  NAKIT
  KREDI_KARTI
  HAVALE_EFT
  DIGER
  MAIL_ORDER
}

enum ReminderStatus {
  AKTIF
  TAMAMLANDI
}

enum TreatmentPlanStatus {
  PLANLANDI
  DEVAM_EDIYOR
  TAMAMLANDI
  IPTAL
}

enum LabOrderStatus {
  DEVAM_EDIYOR
  HASTAYA_TAKILDI
  IPTAL
}

enum ClinicTaskType {
  PARCA_SIPARIS
  LAB
  ARAMA
  EVRAK
  DIGER
}

enum ClinicTaskStatus {
  ACIK
  BEKLEMEDE
  TAMAMLANDI
  IPTAL
}

enum TaksitPeriod {
  HAFTALIK
  IKIHALFTALIK
  AYLIK
  IKIAYLIK
  UCAYLIK
  ALTIAYLIK
  YILLIK
}

enum TaksitPlanStatus {
  AKTIF
  DEVAM_EDIYOR
  TAMAMLANDI
  IPTAL
}

enum TaksitStatus {
  BEKLIYOR
  ODENDI
  GECIKTI
  IPTAL
}

enum FirmaIslemTipi {
  ALIM
  HIZMET
  ODEME
}

enum FirmaKategori {
  TEDARICI
  HIZMET_SAGLAYICI
  LAB
  KONTRAKTOR
  BANK
  DIGER
}

enum PaymentTermType {
  COD
  NET_15
  NET_30
  NET_60
  NET_90
  NET_120
  EOM
  CUSTOM
}

model Document {
  id            String           @id @default(cuid())
  institutionId String?
  patientId     String
  uploadedById  String
  category      DocumentCategory @default(BELGE)
  fileName      String
  storedName    String           @unique
  mimeType      String
  fileSize      Int
  toothNo       String?
  note          String?
  createdAt     DateTime         @default(now())
  patient       Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploadedBy    User             @relation(fields: [uploadedById], references: [id])
  institution   Institution?     @relation(fields: [institutionId], references: [id])

  @@index([patientId])
  @@index([institutionId])
  @@index([category])
}

enum DocumentCategory {
  BELGE
  RONTGEN
  FOTOGRAF
}

model Waitlist {
  id            String         @id @default(cuid())
  institutionId String?
  patientId     String
  doctorId      String?
  createdById   String
  preferredFrom DateTime?
  preferredTo   DateTime?
  note          String?
  status        WaitlistStatus @default(BEKLIYOR)
  // YERLESTIRILDI durumuna geçerken hangi randevunun oluşturulduğu — önceden
  // bu bağ hiç tutulmuyordu, durum elle işaretleniyordu (bkz. denetim raporu
  // Tema 4).
  appointmentId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor        User?          @relation("WaitlistDoctor", fields: [doctorId], references: [id])
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id])
  createdBy     User           @relation("WaitlistCreatedBy", fields: [createdById], references: [id])
  institution   Institution?   @relation(fields: [institutionId], references: [id])

  @@index([institutionId])
  @@index([status])
  @@index([patientId])
  @@index([appointmentId])
}

enum WaitlistStatus {
  BEKLIYOR
  ARANDI
  YERLESTIRILDI
  IPTAL
}

model BookingRequest {
  id                   String               @id @default(cuid())
  institutionId        String
  doctorId             String?
  fullName             String
  phone                String
  tcNo                 String?
  preferredFrom        DateTime
  preferredTo          DateTime?
  note                 String?
  status               BookingRequestStatus @default(BEKLIYOR)
  createdAppointmentId String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  doctor               User?                @relation(fields: [doctorId], references: [id])
  institution          Institution          @relation(fields: [institutionId], references: [id])

  @@index([institutionId])
  @@index([status])
}

enum BookingRequestStatus {
  BEKLIYOR
  ONAYLANDI
  REDDEDILDI
  IPTAL
}
