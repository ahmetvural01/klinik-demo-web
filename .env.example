DATABASE_URL="postgresql://postgres:2653@localhost:5432/klinik_modern?schema=public"
JWT_SECRET="degistir-bunu-guclu-bir-sifre-yap"
APP_NAME="Klinik Modern"
NODE_ENV="development"

# SMTP kilit ekranini acmak icin kullanilan superadmin ana sifresi (zorunlu)
SMTP_MASTER_PASSWORD="degistir-bunu-guclu-bir-sifre-yap"

# Gercek SMS entegrasyonu (NETGSM)
SMS_PROVIDER="NETGSM"
NETGSM_USERCODE=""
NETGSM_PASSWORD=""
NETGSM_HEADER=""

# Not: Coklu saglayici yonetimi artik superadmin panelindeki
# SMS API ekranindan (DB tabanli SmsProviderConfig) yapilir.
# Yukaridaki env degerleri NETGSM fallback icin korunmustur.

# Opsiyonel: SUPERADMIN girisinde ikinci gizli anahtar kontrolu
SUPERADMIN_MASTER_SECRET=""

# Kurumsal olcekli realtime event-bus (opsiyonel ama onerilir)
# Ornek: redis://localhost:6379
REDIS_URL=""

# Opsiyonel: API ve auth yuk limitleme ayarlari (su an kod icinde default)
# API_RATE_LIMIT_PER_MIN=400
# AUTH_RATE_LIMIT_PER_MIN=30
