# Yerel geliştirme için örnek değişkenler.
# Gerçek değerleri bu dosyaya yazmayın; kendi makinenizde .env kullanın.

NODE_ENV="development"
PORT="3000"
APP_URL="http://localhost:3000"
APP_NAME="Klinik Yönetim Paneli"

# PostgreSQL
# Yerel geliştirmede kendi local PostgreSQL bağlantınızı .env içine yazın.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE?schema=public"

# Auth / session
# Üretim ve demo ortamında güçlü, benzersiz değer kullanın.
JWT_SECRET=""

# KVKK kapsamındaki hasta alanları ve belge dosyaları için AES-256-GCM anahtarı.
# Üretmek için:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY=""

# Superadmin SMTP kilit ekranı ana şifresi.
SMTP_MASTER_PASSWORD=""

# SMS sağlayıcı fallback değişkenleri. Asıl sağlayıcı yönetimi superadmin panelinden yapılabilir.
SMS_PROVIDER="NETGSM"
NETGSM_USERCODE=""
NETGSM_PASSWORD=""
NETGSM_HEADER=""

# Opsiyonel: SUPERADMIN girişinde ikinci gizli anahtar kontrolü.
SUPERADMIN_MASTER_SECRET=""

# Opsiyonel: SSE/realtime ve SMS job kuyruğu için Redis.
# Tek Render web service demo kurulumunda boş bırakılabilir.
REDIS_URL=""
SMS_QUEUE_KEY="ks:sms:jobs"

# Opsiyonel test komutları
SMOKE_BASE_URL="http://localhost:3001"
INTEGRATION_BASE_URL="http://localhost:3001"

# Opsiyonel demo veri yükleme scripti için test parolası.
DEMO_PASSWORD=""
